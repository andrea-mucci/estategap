{
  "uid": "estategap-alert-latency",
  "title": "EstateGap — Alert Latency",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "timezone": "browser",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Alert Processing p99",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, rate(estategap_alert_processing_duration_seconds_bucket[5m]))",
          "legendFormat": "p99 latency"
        }
      ]
    }
  ]
}
