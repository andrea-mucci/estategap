{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EstateGap Helm Values",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "registry": {
      "type": "string",
      "pattern": "^$|^(localhost(?::[0-9]+)?|[a-z][a-z0-9.-]*(?::[0-9]+)?)$"
    },
    "imageSpec": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "repository",
        "tag"
      ],
      "additionalProperties": true
    },
    "storageSpec": {
      "type": "object",
      "properties": {
        "size": {
          "type": "string",
          "minLength": 1
        },
        "storageClass": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "hpaSpec": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "minReplicas": {
          "type": "integer",
          "minimum": 1
        },
        "maxReplicas": {
          "type": "integer",
          "minimum": 1
        },
        "cpuTarget": {
          "type": "number",
          "minimum": 1
        }
      },
      "additionalProperties": true
    },
    "serviceMonitorSpec": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "path": {
          "type": "string"
        },
        "interval": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "kedaServiceSpec": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "minReplicas": {
          "type": "integer",
          "minimum": 1
        },
        "maxReplicas": {
          "type": "integer",
          "minimum": 1
        },
        "stream": {
          "type": "string"
        },
        "consumer": {
          "type": "string"
        },
        "lagThreshold": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "global": {
      "type": "object",
      "properties": {
        "storageClass": {
          "type": "string"
        },
        "imageRegistry": {
          "$ref": "#/$defs/registry"
        },
        "imagePullSecrets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "testMode": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "cluster": {
      "type": "object",
      "properties": {
        "environment": {
          "type": "string",
          "enum": [
            "test",
            "staging",
            "production"
          ]
        },
        "domain": {
          "type": "string",
          "minLength": 1
        },
        "certIssuer": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "testMode": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "nowOverride": {
          "type": "string"
        },
        "stripeWebhookSecret": {
          "type": "string",
          "minLength": 1
        },
        "fixtureS3Bucket": {
          "type": "string",
          "minLength": 1
        },
        "fakeLLMProvider": {
          "type": "boolean"
        },
        "scheduleOverride": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "enabled",
        "nowOverride",
        "stripeWebhookSecret",
        "fixtureS3Bucket",
        "fakeLLMProvider",
        "scheduleOverride"
      ],
      "additionalProperties": false
    },
    "observabilityComponent": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "kafka": {
      "type": "object",
      "properties": {
        "brokers": {
          "type": "string",
          "minLength": 1
        },
        "topicPrefix": {
          "type": "string",
          "minLength": 1
        },
        "tls": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            }
          },
          "additionalProperties": true
        },
        "sasl": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "username": {
              "type": "string"
            },
            "secretName": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "consumer": {
          "type": "object",
          "properties": {
            "maxRetries": {
              "type": "integer",
              "minimum": 1
            }
          },
          "additionalProperties": true
        },
        "initJob": {
          "type": "object",
          "properties": {
            "replicationFactor": {
              "type": "integer",
              "minimum": 1
            },
            "image": {
              "$ref": "#/$defs/imageSpec"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "postgresql": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "imageName": {
          "type": "string"
        },
        "instances": {
          "type": "integer",
          "minimum": 1
        },
        "database": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "storage": {
          "$ref": "#/$defs/storageSpec"
        },
        "backup": {
          "type": "object",
          "additionalProperties": true
        },
        "resources": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "redis": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "fullnameOverride": {
          "type": "string"
        },
        "architecture": {
          "type": "string",
          "enum": [
            "standalone",
            "replication"
          ]
        },
        "auth": {
          "type": "object",
          "additionalProperties": true
        },
        "sentinel": {
          "type": "object",
          "additionalProperties": true
        },
        "master": {
          "type": "object",
          "additionalProperties": true
        },
        "replica": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "s3": {
      "type": "object",
      "properties": {
        "endpoint": {
          "type": "string",
          "minLength": 1
        },
        "region": {
          "type": "string",
          "minLength": 1
        },
        "bucketPrefix": {
          "type": "string",
          "minLength": 1
        },
        "forcePathStyle": {
          "type": "boolean"
        },
        "credentials": {
          "type": "object",
          "properties": {
            "secret": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": true
        },
        "buckets": {
          "type": "object",
          "properties": {
            "mlModels": {
              "type": "string",
              "minLength": 1
            },
            "trainingData": {
              "type": "string",
              "minLength": 1
            },
            "listingPhotos": {
              "type": "string",
              "minLength": 1
            },
            "exports": {
              "type": "string",
              "minLength": 1
            },
            "backups": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "serviceSpec": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "namespace": {
          "type": "string"
        },
        "replicaCount": {
          "type": "integer",
          "minimum": 1
        },
        "port": {
          "type": "integer",
          "minimum": 1
        },
        "metricsPort": {
          "type": "integer",
          "minimum": 1
        },
        "image": {
          "$ref": "#/$defs/imageSpec"
        },
        "resources": {
          "type": "object",
          "additionalProperties": true
        },
        "env": {
          "type": "object",
          "additionalProperties": true
        },
        "command": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "serviceMonitor": {
          "$ref": "#/$defs/serviceMonitorSpec"
        },
        "hpa": {
          "$ref": "#/$defs/hpaSpec"
        },
        "keda": {
          "$ref": "#/$defs/kedaServiceSpec"
        },
        "config": {
          "type": "object",
          "additionalProperties": true
        },
        "livenessProbe": {
          "type": "object",
          "additionalProperties": true
        },
        "readinessProbe": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "services": {
      "type": "object",
      "patternProperties": {
        ".*": {
          "$ref": "#/$defs/serviceSpec"
        }
      },
      "additionalProperties": false
    },
    "toggleBlock": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    }
  },
  "properties": {
    "global": {
      "$ref": "#/$defs/global"
    },
    "cluster": {
      "$ref": "#/$defs/cluster"
    },
    "cnpg": {
      "type": "object",
      "additionalProperties": true
    },
    "kafka": {
      "$ref": "#/$defs/kafka"
    },
    "postgresql": {
      "$ref": "#/$defs/postgresql"
    },
    "redis": {
      "$ref": "#/$defs/redis"
    },
    "s3": {
      "$ref": "#/$defs/s3"
    },
    "observability": {
      "type": "object",
      "properties": {
        "prometheus": {
          "$ref": "#/$defs/observabilityComponent"
        },
        "loki": {
          "$ref": "#/$defs/observabilityComponent"
        },
        "tempo": {
          "$ref": "#/$defs/observabilityComponent"
        }
      },
      "additionalProperties": true
    },
    "prometheus": {
      "$ref": "#/$defs/toggleBlock"
    },
    "loki": {
      "$ref": "#/$defs/toggleBlock"
    },
    "tempo": {
      "$ref": "#/$defs/toggleBlock"
    },
    "keda": {
      "$ref": "#/$defs/toggleBlock"
    },
    "argocd": {
      "$ref": "#/$defs/toggleBlock"
    },
    "sealedSecrets": {
      "type": "object",
      "additionalProperties": true
    },
    "stripe": {
      "type": "object",
      "additionalProperties": true
    },
    "mlTrainer": {
      "type": "object",
      "properties": {
        "image": {
          "$ref": "#/$defs/imageSpec"
        }
      },
      "additionalProperties": true
    },
    "mlScorer": {
      "type": "object",
      "additionalProperties": true
    },
    "gdpr": {
      "type": "object",
      "additionalProperties": true
    },
    "loadTests": {
      "type": "object",
      "additionalProperties": true
    },
    "services": {
      "$ref": "#/$defs/services"
    },
    "testMode": {
      "$ref": "#/$defs/testMode"
    }
  }
}
